# Copy this file to helion.properties and fill in real values.

helion.manager.provider=openai
helion.manager.model=gpt-4o-mini
helion.openai.api_key=replace_me

helion.worker.provider=llama.cpp
helion.worker.model=your-loaded-model-name
helion.worker.count=3
helion.llamacpp.url=http://localhost:8080

# Named local model pools. If omitted, Helion creates a single "default" pool
# from the worker provider/model/count/url values above.
helion.local.pool.default=default
# helion.local.pool.names=default,deep
# helion.local.pool.default.provider=llama.cpp
# helion.local.pool.default.model=your-loaded-model-name
# helion.local.pool.default.url=http://localhost:8080
# helion.local.pool.default.capacity=2
# helion.local.pool.deep.provider=llama.cpp
# helion.local.pool.deep.model=your-large-model
# helion.local.pool.deep.url=http://localhost:8081
# helion.local.pool.deep.capacity=1

helion.enable.browser=true
helion.browser.result_limit=5
helion.browser.fetch_char_limit=4000

helion.enable.memory=true
helion.memory.dir=.helion/memory
helion.memory.namespace=default
helion.memory.max_entries=24
helion.memory.entry_char_limit=2500

helion.enable.knowledge=true
helion.knowledge.dir=knowledge
helion.knowledge.char_limit=12000

helion.agents.dir=agents
helion.company_data.dir=company_data
helion.company_data.sources_file=.helion/company_data_sources.txt
helion.company_data.char_limit=12000

helion.web.host=127.0.0.1
helion.web.port=8421

helion.usage.events_file=.helion/usage_events.tsv

helion.email.enabled=false
helion.email.provider=imap_smtp
helion.email.display_name=Arma Automotive
helion.email.address=you@example.com
helion.email.imap.host=imap.example.com
helion.email.imap.port=993
helion.email.imap.username=you@example.com
helion.email.imap.password=replace_me
helion.email.imap.ssl=true
helion.email.imap.drafts_folder=Drafts
helion.email.smtp.host=smtp.example.com
helion.email.smtp.port=465
helion.email.smtp.username=you@example.com
helion.email.smtp.password=replace_me
helion.email.smtp.ssl=true

helion.max.turns=6
